{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Defaults",
  "type": "object",
  "required": ["organization", "domains", "system"],
  "additionalProperties": false,
  "properties": {
    "organization": {
      "type": "object",
      "required": ["name", "email"],
      "additionalProperties": false,
      "properties": {
        "email": { "type": "string" },
        "managed_comment": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "domains": {
      "type": "object",
      "required": ["acme", "external", "internal"],
      "additionalProperties": false,
      "properties": {
        "acme": { "type": "string", "description": "Domain used for DNS-01 ACME challenge delegation" },
        "external": { "type": "string", "description": "Public-facing domain" },
        "internal": { "type": "string", "description": "Internal Tailscale domain" }
      }
    },
    "system": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "locale": { "type": "string" },
        "shell": { "type": "string" },
        "timezone": { "type": "string" }
      }
    },
    "bitwarden": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "collections": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "servers": { "type": "string" },
            "services": { "type": "string" }
          }
        },
        "organization": { "type": "string" },
        "url_field_pattern": {
          "type": "string",
          "description": "Regex matching server/service fields to store as Bitwarden URIs"
        }
      }
    },
    "dns": {
      "type": "object",
      "description": "Default values merged into all DNS records",
      "additionalProperties": false,
      "properties": {
        "priority": { "type": ["integer", "null"] },
        "proxied": { "type": "boolean" },
        "ttl": { "type": "integer" },
        "wildcard": { "type": "boolean" }
      }
    },
    "github": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "owner": { "type": "string" },
        "repositories": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fly": { "type": "string" },
            "komodo": { "type": "string" },
            "truenas": { "type": "string" }
          }
        }
      }
    },
    "resend": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer" },
        "username": { "type": "string" }
      }
    },
    "servers": {
      "type": "object",
      "description": "Default values merged into all server YAML files"
    },
    "services": {
      "type": "object",
      "description": "Default values merged into all service YAML files"
    },
    "tailscale": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "admin_identities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
