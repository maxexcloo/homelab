{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "fileMatch": ["(^|/)templates/.+\\.ya?ml\\.tftpl$"],
      "matchStrings": [
        "(?m)^\\s*image:\\s*(?<depName>[^\\s:@]+(?:/[^\\s:@]+)*):(?<currentValue>[^\\s@#]+)"
      ]
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)templates/.+\\.ya?ml\\.tftpl$"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: extractVersion=(?<extractVersion>\\S+))?(?: versioning=(?<versioning>\\S+))?\\s*\\n\\s*-\\s*[A-Z0-9_]*VERSION=(?<currentValue>[^\\s]+)"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "fileMatch": ["(^|/)templates/.+\\.ya?ml\\.tftpl$"],
      "matchStrings": [
        "https://github\\.com/(?<depName>[^/]+/[^/]+)/releases/(?<currentValue>v?\\d[^/$]*)/download/",
        "https://github\\.com/(?<depName>[^/]+/[^/]+)/releases/download/(?<currentValue>v?\\d[^/$]*)/"
      ],
      "versioningTemplate": "loose"
    }
  ],
  "dependencyDashboard": true,
  "extends": ["config:recommended"],
  "ignoreDeps": ["hashicorp/terraform"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group GitHub Actions updates from workflow templates",
      "groupName": "GitHub Actions",
      "matchManagers": ["github-actions"]
    },
    {
      "description": "Resolve OpenTofu provider updates from the OpenTofu registry",
      "matchDatasources": ["terraform-module", "terraform-provider"],
      "registryUrls": ["https://registry.opentofu.org"]
    },
    {
      "description": "Group mise tool updates",
      "groupName": "mise tools",
      "matchManagers": ["mise"]
    },
    {
      "description": "Pin Docker image digests in templates and Dockerfiles",
      "matchDatasources": ["docker"],
      "pinDigests": true
    }
  ],
  "prConcurrentLimit": 20,
  "rangeStrategy": "bump"
}
