{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "extends": ["config:recommended"],
  "ignoreDeps": ["hashicorp/terraform"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 20,
  "rangeStrategy": "bump",
  "rebaseWhen": "behind-base-branch",
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "managerFilePatterns": ["/(^|/)templates/.+\\.ya?ml\\.tftpl$/"],
      "matchStrings": [
        "(?:^|\\r?\\n)\\s*image:\\s*(?<depName>[^\\s:@]+(?:/[^\\s:@]+)*):(?<currentValue>[^\\s@#]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "currentValueTemplate": "latest",
      "datasourceTemplate": "docker",
      "managerFilePatterns": ["/(^|/)templates/.+\\.ya?ml\\.tftpl$/"],
      "matchStrings": [
        "(?:^|\\r?\\n)\\s*image:\\s*(?<depName>[^\\s:@]+(?:/[^\\s:@]+)*)@(?<currentDigest>sha256:[a-f0-9]+)"
      ],
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "jdx/mise",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "managerFilePatterns": ["/(^|/)\\.github/workflows/.+\\.ya?ml$/"],
      "matchStrings": [
        "uses:\\s+jdx/mise-action@\\S+\\s+with:\\s+version:\\s+(?<currentValue>\\S+)"
      ],
      "versioningTemplate": "semver-coerced"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Group GitHub Actions updates",
      "groupName": "GitHub Actions",
      "matchManagers": ["github-actions"]
    },
    {
      "description": "Resolve OpenTofu provider updates from the OpenTofu registry",
      "matchDatasources": ["terraform-module", "terraform-provider"],
      "registryUrls": ["https://registry.opentofu.org"]
    },
    {
      "description": "Group mise tool updates",
      "groupName": "mise tools",
      "matchManagers": ["mise"]
    },
    {
      "description": "Pin Docker image digests in templates and Dockerfiles",
      "matchDatasources": ["docker"],
      "pinDigests": true
    },
    {
      "automerge": true,
      "description": "Automerge passing digest, patch, and pin updates",
      "matchUpdateTypes": ["digest", "patch", "pin", "pinDigest"]
    }
  ],
  "pre-commit": {
    "enabled": true
  }
}
