version: 1.3.12
cache: true
endpoints:
  custom:
    - name: DeepSeek
      apiKey: $${DEEPSEEK_API_KEY}
      baseURL: https://api.deepseek.com/v1
      modelDisplayLabel: DeepSeek
      titleConvo: true
      titleModel: ${defaults.ai.default_model}
      models:
        fetch: true
        default:
          - ${defaults.ai.default_model}
    - name: OpenCode Go
      apiKey: $${OPENCODE_API_KEY}
      baseURL: https://opencode.ai/zen/go/v1
      modelDisplayLabel: OpenCode Go
      titleConvo: true
      titleModel: ${defaults.ai.default_model}
      models:
        fetch: true
        default:
          - ${defaults.ai.default_model}
    - name: OpenRouter
      apiKey: $${OPENROUTER_KEY}
      baseURL: https://openrouter.ai/api/v1
      modelDisplayLabel: OpenRouter
      titleConvo: true
      titleModel: ${defaults.ai.default_model_provider}/${defaults.ai.default_model}
      dropParams:
        - stop
      models:
        fetch: true
        default:
          - ${defaults.ai.default_model_provider}/${defaults.ai.default_model}
mcpSettings:
  allowedDomains:
    %{~ for zone in zones ~}
    - "${zone}"
    - "*.${zone}"
    %{~ endfor ~}
