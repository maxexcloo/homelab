version: 1.3.12
cache: true
endpoints:
  custom:
    - name: DeepSeek
      apiKey: $${DEEPSEEK_API_KEY}
      baseURL: https://api.deepseek.com/v1
      modelDisplayLabel: DeepSeek
      titleConvo: true
      titleModel: deepseek-v4-flash
      models:
        fetch: true
        default:
          - deepseek-v4-flash
    - name: OpenCode Go
      apiKey: $${OPENCODE_API_KEY}
      baseURL: https://opencode.ai/zen/go/v1
      modelDisplayLabel: OpenCode Go
      titleConvo: true
      titleModel: deepseek-v4-flash
      models:
        fetch: true
        default:
          - deepseek-v4-flash
    - name: OpenRouter
      apiKey: $${OPENROUTER_KEY}
      baseURL: https://openrouter.ai/api/v1
      modelDisplayLabel: OpenRouter
      titleConvo: true
      titleModel: deepseek/deepseek-v4-flash
      dropParams:
        - stop
      models:
        fetch: true
        default:
          - deepseek/deepseek-v4-flash
mcpSettings:
  allowedDomains:
    - "*.${defaults.domains.external}"
    - "*.${defaults.domains.internal}"
    - "${defaults.domains.external}"
    - "${defaults.domains.internal}"
