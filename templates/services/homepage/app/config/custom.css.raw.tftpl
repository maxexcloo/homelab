:root {
  --homepage-card-bg: rgba(0, 0, 0, 0.15);
  --homepage-card-radius: 15px;
  --tw-shadow-color: none;
}

html,
body {
  -webkit-font-smoothing: auto !important;
  font-size: 120% !important;
  text-rendering: auto !important;
}

.rounded,
.rounded-md {
  border-radius: var(--homepage-card-radius) !important;
}

.bookmark > a,
.service-card {
  background: var(--homepage-card-bg) !important;
  box-shadow: none !important;
}

.service-card {
  transition: none !important;
}

.service-block {
  background: transparent !important;
}

.service-container {
  background: var(--homepage-card-bg) !important;
  border-radius: var(--homepage-card-radius);
}

.service-card > *:nth-child(n + 3) > div {
  margin-top: 0 !important;
  padding-top: 0 !important;
}

.service-title {
  position: relative;
}

.service-tags {
  bottom: 0;
}

.site-monitor-status {
  height: 100%;
  padding: 8px 4px !important;
}

.site-monitor-status > .rounded-full {
  border-radius: var(--homepage-card-radius) !important;
  height: 100% !important;
  width: 6px !important;
}
