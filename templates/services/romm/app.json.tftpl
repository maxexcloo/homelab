{
  "values": {
    "network": {
      "web_port": {
        "bind_mode": "published",
        "port_number": ${service.routing.port}
      }
    },
    "romm": {
      "auth_secret_key": "${service.runtime.secrets.auth_secret_key}",
      "db_password": "${service.runtime.secrets.db_password}",
      "igdb_client_id": "${service.runtime.secrets.igdb_client_id}",
      "igdb_client_secret": "${service.runtime.secrets.igdb_client_secret}",
      "mobygames_api_key": "",
      "postgres_image_selector": "postgres_18_image",
      "redis_password": "${service.runtime.secrets.redis_password}",
      "steamgriddb_api_key": "${service.runtime.secrets.steamgriddb_api_key}"
    },
    "storage": {
      "assets": {
        "host_path_config": {
          "acl_enable": false,
          "path": "/mnt/truenas-nvme/romm/assets"
        },
        "type": "host_path"
      },
      "config": {
        "ix_volume_config": {
          "acl_enable": false,
          "dataset_name": "config"
        },
        "type": "ix_volume"
      },
      "library": {
        "host_path_config": {
          "acl_enable": false,
          "path": "/mnt/truenas-nvme/romm/library"
        },
        "type": "host_path"
      },
      "postgres_data": {
        "ix_volume_config": {
          "acl_enable": false,
          "dataset_name": "pg_data"
        },
        "type": "ix_volume"
      },
      "resources": {
        "host_path_config": {
          "acl_enable": false,
          "path": "/mnt/truenas-nvme/romm/resources"
        },
        "type": "host_path"
      }
    }
  }
}
