services:
  periphery:
    environment:
      PERIPHERY_PASSKEY: ${server.runtime.secrets.komodo_passkey}
      SOPS_AGE_KEY: ${server.runtime.secrets.age_secret_key}
    image: ghcr.io/moghtech/komodo-periphery:2.2.0
    network_mode: host
    restart: unless-stopped
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
