${join("\n", compact([
  service.features.pushover ? "PUSHOVER_APPLICATION_TOKEN=\"${service.state.secrets.pushover_application_token}\"" : "",
  service.features.pushover ? "PUSHOVER_USER_KEY=\"${service.state.secrets.pushover_user_key}\"" : "",
  service.features.resend ? "RESEND_API_KEY=\"${service.state.secrets.resend_api_key}\"" : "",
  service.features.tailscale ? "TAILSCALE_AUTH_KEY=\"${service.state.secrets.tailscale_auth_key}\"" : ""
]))}
