${join("\n", compact([
  "GATUS_MONITORING_TOKEN=\"${service.runtime.credentials.monitoring_token}\"",
  service.features.resend ? "RESEND_API_KEY=\"${service.runtime.credentials.resend_api_key}\"" : "",
  service.features.tailscale ? "TAILSCALE_AUTH_KEY=\"${service.runtime.credentials.tailscale_auth_key}\"" : ""
]))}
