services:
  beszel-agent:
    image: henrygd/beszel-agent
    environment:
      HUB_URL: http://localhost:${services.beszel.routing.port}
      KEY: ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIPkxnKuxsVqSVZVXQ3OGHjZZFMAAclU/xLrEDdwOyRt+
      LISTEN: 45876
      TOKEN: ${service.state.secrets.token}
    network_mode: host
    restart: unless-stopped
    volumes:
      - /var/run/dbus/system_bus_socket:/var/run/dbus/system_bus_socket:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - data:/var/lib/beszel-agent
volumes:
  data:
