secrets:
  dozzle_cert:
    file: ./dozzle_cert.pem
  dozzle_key:
    file: ./dozzle_key.pem
services:
  dozzle-agent:
    command: agent
    environment:
      DOZZLE_HOSTNAME: ${server.key}
    image: amir20/dozzle:v10.6.11
    ports:
      - 7007:7007
    restart: unless-stopped
    secrets:
      - source: dozzle_cert
        target: /dozzle_cert.pem
      - source: dozzle_key
        target: /dozzle_key.pem
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
