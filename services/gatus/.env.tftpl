PUSHOVER_USER_KEY="${service.pushover_user_key_sensitive}"
%{ endif ~}
%{ if service.features.resend ~}
RESEND_API_KEY="${service.resend_api_key_sensitive}"
%{ endif ~}
%{ if service.features.tailscale ~}
TAILSCALE_AUTH_KEY="${service.tailscale_auth_key_sensitive}"
%{ endif ~}
